# Sambar - VINTAGE_ONLY profile example
# MS-DOS and Windows 3.11 only (LANMAN1-NT1, port 139, plaintext auth)

CONTAINER_NAME=samba-vintage
WORKGROUP=WORKGROUP
TZ=America/New_York
INTERFACES=lo eth0
PROFILE=VINTAGE_ONLY

# Share names
SHARE_1=docs
SHARE_2=media
SHARE_3=tools
SHARE_4=shared
SHARE_5=
SHARE_6=
SHARE_7=
SHARE_8=

# Volume mounts
VOL_1_SRC=/srv/samba/documents
VOL_1_DST=/mnt/docs
VOL_1_MODE=ro
VOL_2_SRC=/srv/samba/media
VOL_2_DST=/mnt/media
VOL_2_MODE=ro
VOL_3_SRC=/srv/samba/tools
VOL_3_DST=/mnt/tools
VOL_3_MODE=ro
VOL_4_SRC=/srv/samba/shared
VOL_4_DST=/mnt/shared
VOL_4_MODE=rw
VOL_5_SRC=/dev/null
VOL_5_DST=/mnt/slot5
VOL_5_MODE=ro
VOL_6_SRC=/dev/null
VOL_6_DST=/mnt/slot6
VOL_6_MODE=ro
VOL_7_SRC=/dev/null
VOL_7_DST=/mnt/slot7
VOL_7_MODE=ro
VOL_8_SRC=/dev/null
VOL_8_DST=/mnt/slot8
VOL_8_MODE=ro
